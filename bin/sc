#!/bin/bash
set -euo pipefail

COMMANDS_DIR="$(dirname "$(realpath "$0")")/sc-commands"

if [[ $# -lt 1 ]]; then
  echo "Usage: sc <command> [args...]"
  echo "       sc <module> <action> [args...]"
  echo
  if [[ -d "$COMMANDS_DIR" ]]; then
    # List standalone commands
    for cmd_file in "$COMMANDS_DIR"/*; do
      [[ -x "$cmd_file" && -f "$cmd_file" ]] && echo "  sc $(basename "$cmd_file") ..."
    done
    # List module/action commands
    for module_dir in "$COMMANDS_DIR"/*/; do
      [[ -d "$module_dir" ]] || continue
      module="$(basename "$module_dir")"
      actions=()
      for action_file in "$module_dir"/*; do
        [[ -x "$action_file" ]] && actions+=("$(basename "$action_file")")
      done
      if [[ ${#actions[@]} -gt 0 ]]; then
        echo "  sc $module {$(IFS='|'; echo "${actions[*]}")}"
      fi
    done
  fi
  exit 1
fi

# Try standalone command first
cmd="$COMMANDS_DIR/$1"
if [[ -x "$cmd" && -f "$cmd" ]]; then
  shift
  exec "$cmd" "$@"
fi

# Then try module/action
if [[ $# -lt 2 ]]; then
  echo "Error: unknown command 'sc $1'"
  exit 1
fi

module="$1"
action="$2"
shift 2

cmd="$COMMANDS_DIR/$module/$action"

if [[ ! -x "$cmd" ]]; then
  echo "Error: unknown command 'sc $module $action'"
  exit 1
fi

exec "$cmd" "$@"
